{
  "name": "vs-code-workspace-picker",
  "displayName": "VS Code Workspace Picker",
  "description": "A sidebar-based VS Code workspace launcher with WSL support, Git worktree creation, and quick switching between known workspaces.",
  "version": "0.0.1",
  "publisher": "ArminEberle",
  "license": "MIT",
  "icon": "media/icon.png",
  "homepage": "https://github.com/ArminEberle/vs-code-workspace-picker",
  "bugs": {
    "url": "https://github.com/ArminEberle/vs-code-workspace-picker/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArminEberle/vs-code-workspace-picker.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "workspace",
    "workspaces",
    "workspace switcher",
    "wsl",
    "git",
    "worktree",
    "repository",
    "sidebar"
  ],
  "activationEvents": [
    "onView:workspacePicker.knownWorkspaces",
    "onCommand:workspacePicker.openKnown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workspacePicker",
          "title": "Workspace Picker",
          "icon": "media/workspace-picker.svg"
        }
      ]
    },
    "views": {
      "workspacePicker": [
        {
          "id": "workspacePicker.knownWorkspaces",
          "name": "Known Workspaces",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "workspacePicker.openKnown",
        "title": "Focus Known Workspaces"
      },
      {
        "command": "workspacePicker.addNew",
        "title": "Add New"
      },
      {
        "command": "workspacePicker.addCurrent",
        "title": "Add This"
      },
      {
        "command": "workspacePicker.refresh",
        "title": "Refresh"
      },
      {
        "command": "workspacePicker.openEntry",
        "title": "Open"
      },
      {
        "command": "workspacePicker.openEntryInNewWindow",
        "title": "Open in New Window"
      },
      {
        "command": "workspacePicker.removeEntry",
        "title": "Remove from List"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "workspacePicker.openKnown"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run build",
    "package:vsix": "vsce package",
    "publish:marketplace": "vsce publish",
    "pretest": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.8.3"
  }
}
